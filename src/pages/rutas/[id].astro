---
import { getRutaById } from "../../lib/rutas";
import { getRutaImageUrl, getGpxFileUrl } from "../../lib/utils";
import { getMarkdownProcessor } from "../../lib/markdown";

import BtnRutas from "../../components/BtnRutas.astro";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/rutas");
}

const ruta = await getRutaById(id);

if (!ruta) {
  return Astro.redirect("/rutas");
}

const { titulo, destino, distancia, desnivel, gpx, wikiloc, dificultad, portada, descripcion } = ruta;

const gpxFileUrl = getGpxFileUrl(gpx);

let images: string[] = [];
try {
  const { supabase } = await import("../../lib/supabase");
  if (supabase) {
    const { data: storageFiles } = await supabase.storage.from("rutas-imagenes").list(id);
    images = (storageFiles ?? [])
      .filter((f) => f.name !== portada)
      .map((f) => getRutaImageUrl(id, f.name));
  }
} catch (error) {
  console.error("Error al obtener imágenes de la ruta:", error);
}

const portadaUrl = getRutaImageUrl(id, portada);

const processor = await getMarkdownProcessor();
const { code: descripcionHtml } = await processor.render(descripcion);

const dificultadClass =
  dificultad === "Fácil"
    ? "bg-facil"
    : dificultad === "Moderada"
      ? "bg-moderada"
      : dificultad === "Difícil"
        ? "bg-dificil"
        : "bg-gray-200 text-gray-800";

const pageTitle = `Ciclo Family | ${titulo}`;
const pageDescription = `Descubre la ruta en bicicleta ${titulo} en ${destino}. ${distancia} km de distancia, ${desnivel} m de desnivel. Dificultad ${dificultad}. Ideal para familias y ciclistas.`;
const canonicalUrl = `${Astro.url.origin}/rutas/${id}`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={portadaUrl}
  url={canonicalUrl}
  type="article"
  keywords={`rutas en bicicleta, ${destino}, ${titulo}, ciclismo Catalunya, rutas familiares, ${dificultad}`}
>
  <!-- Structured Data: TouristTrip -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    "name": titulo,
    "description": pageDescription,
    "url": canonicalUrl,
    "image": portadaUrl,
    "touristType": "Familia Ciclista",
    "itinerary": {
      "@type": "ItemList",
      "numberOfItems": 1,
      "itemListElement": {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Place",
          "name": destino,
          "description": `Ruta de ${distancia} km con ${desnivel} m de desnivel en ${destino}`
        }
      }
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    },
    "provider": {
      "@type": "Organization",
      "name": "Ciclo Family",
      "url": "https://ciclofamily.vercel.app"
    }
  })} />

  <!-- Structured Data: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://ciclofamily.vercel.app/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Rutas",
        "item": "https://ciclofamily.vercel.app/rutas"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": titulo,
        "item": canonicalUrl
      }
    ]
  })} />

  <Header />
  
  <main class="w-[90%] m-auto">
    <nav aria-label="Breadcrumb" class="text-sm text-gray-600 mx-8 pt-4">
      <ol class="flex items-center gap-1">
        <li><a href="/" class="hover:underline hover:text-page-400 transition">Inicio</a></li>
        <li aria-hidden="true" class="text-gray-400">›</li>
        <li><a href="/rutas" class="hover:underline hover:text-page-400 transition">Rutas</a></li>
        <li aria-hidden="true" class="text-gray-400">›</li>
        <li class="text-page-400 font-medium">{titulo}</li>
      </ol>
    </nav>

    <section class="flex items-center gap-4 m-4">
      <h1 class="text-2xl font-semibold">{titulo}</h1>
      <span class={`${dificultadClass} font-medium rounded-xl px-2 py-1`}>{dificultad}</span>
    </section>

    <div id="route-map-wrapper" class="route-map-wrapper z-0">
      <div id="route-map" class="w-full flex-1"></div>
      <button id="fullscreen-btn" class="fullscreen-map-btn" type="button" title="Pantalla completa">
        <svg id="fs-icon-expand" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
        <svg id="fs-icon-shrink" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="4 14 10 14 10 20"></polyline><polyline points="20 10 14 10 14 4"></polyline><line x1="14" y1="10" x2="21" y2="3"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
      </button>

      <button id="elevation-toggle" class="elevation-toggle-btn z-0" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
        <span>Perfil de elevación</span>
        <svg id="elevation-arrow" class="elevation-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>

      <div id="elevation-profile" class="elevation-profile-hidden">
        <div id="elevation-div"></div>
      </div>
    </div>

    <section class="bg-page-200/60 p-4 flex flex-wrap gap-4 rounded-xl my-2 sm:my-6 border-black border">
        <span class="flex items-center gap-1 mx-auto"><img class="size-7" src="/icons/ubicacion.svg" alt="Icono de ubicación"/><span class="flex flex-col sm:mx-2">Destino<b>{destino}</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/distancia.svg" alt="Icono de distancia"/><span class="flex flex-col sm:mx-2">Distancia<b id="stat-distancia">{distancia} km</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/desnivel.svg" alt="Icono de desnivel"/><span class="flex flex-col sm:mx-2">Desnivel<b id="stat-desnivel">{desnivel} m</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/max.svg" alt="Icono de altitud máxima"/><span class="flex flex-col sm:mx-2">Altitud Máx<b id="alt-max">...</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/min.svg" alt="Icono de altitud mínima"/><span class="flex flex-col sm:mx-2">Altitud Mín<b id="alt-min">...</b></span></span>
      </section>

      <section class="flex flex-row gap-4 items-center text-sm sm:text-lg mt-4 sm:my-0">
        <a href={gpxFileUrl} class="bg-page-300/80 px-4 py-2 rounded-lg hover:bg-page-200 transition flex" target="_blank" rel="noopener noreferrer">Descargar GPX</a>
        <a href={wikiloc} class="bg-page-400 text-white hover:text-black rounded-lg py-2 px-4 hover:bg-page-200 transition flex items-center" target="_blank">Ver en <img class="ml-1 h-4 md:h-6" src="/Wikiloc.png" alt="Logo de Wikiloc" /></a>
      </section>

      <div id="mapa-leaflet-scripts">
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
        <link rel="stylesheet" href="https://unpkg.com/leaflet-fullscreen@1.0.2/dist/leaflet.fullscreen.css" />
        <link rel="stylesheet" href="https://unpkg.com/@raruto/leaflet-elevation@2.5.2/dist/leaflet-elevation.css" />
        <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
        <script is:inline src="https://unpkg.com/leaflet-fullscreen@1.0.2/dist/Leaflet.fullscreen.js"></script>
        <script is:inline src="https://unpkg.com/@tmcw/togeojson@7.1.2/dist/togeojson.umd.js" crossorigin=""></script>
        <script is:inline src="https://unpkg.com/leaflet-gpx@2.2.0/gpx.js" crossorigin=""></script>
        <script is:inline src="https://unpkg.com/@raruto/leaflet-elevation@2.5.2/dist/leaflet-elevation.js" crossorigin=""></script>
        <script define:vars={{ gpx, gpxFileUrl }} is:inline>
          document.addEventListener('DOMContentLoaded', function() {
            var map = L.map('route-map', {
              fullscreenControl: true,
              fullscreenControlOptions: { position: 'topright' }
            }).setView([41.5, 2.0], 8);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
              attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
            }).addTo(map);

            var elevationControl = L.control.elevation({
              detached: true,
              elevationDiv: '#elevation-div',
              theme: 'lightblue-theme',
              hotline: 'elevation',
              altitude: true,
              distance: true,
              time: true,
              summary: 'inline',
              collapsed: false,
              closeBtn: true,
              downloadLink: false,
              autofitBounds: true,
              height: 180,
              margins: { top: 20, right: 20, bottom: 25, left: 50 },
              xLabel: 'km',
              yLabel: 'm',
              srcFolder: 'https://unpkg.com/@raruto/leaflet-elevation@2.5.2/src/'
            }).addTo(map);

            elevationControl._customAscent = 0;
            elevationControl.on('elepoint_added', function(e) {
              var idx = e.index;
              var data = elevationControl._data;
              if (idx > 0 && data[idx] && data[idx - 1]) {
                var dz = data[idx].z - data[idx - 1].z;
                if (dz > 0) elevationControl._customAscent += dz;
              }
            });

            elevationControl.load(gpxFileUrl);

            function haversine(lat1, lon1, lat2, lon2) {
              var R = 6371;
              var dLat = (lat2 - lat1) * Math.PI / 180;
              var dLon = (lon2 - lon1) * Math.PI / 180;
              var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon / 2) * Math.sin(dLon / 2);
              return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            }

            function updateStatsFromTrackInfo() {
              var info = elevationControl.track_info || {};
              var gain = Math.round(elevationControl._customAscent || 0);
              var altMax = Math.round(info.elevation_max || 0);
              var altMin = Math.round(info.elevation_min || 0);

              var data = elevationControl._data || [];
              var totalDist = 0;
              for (var i = 1; i < data.length; i++) {
                totalDist += haversine(
                  data[i - 1].latlng.lat, data[i - 1].latlng.lng,
                  data[i].latlng.lat, data[i].latlng.lng
                );
              }
              var distKm = totalDist.toFixed(1);

              var distEl = document.getElementById('stat-distancia');
              if (distEl) distEl.textContent = distKm + ' km';

              var gainEl = document.getElementById('stat-desnivel');
              if (gainEl) gainEl.textContent = gain + ' m';

              var maxEl = document.getElementById('alt-max');
              if (maxEl) maxEl.textContent = altMax + ' m';

              var minEl = document.getElementById('alt-min');
              if (minEl) minEl.textContent = altMin + ' m';
            }

            elevationControl.on('elechart_summary', function() {
              updateStatsFromTrackInfo();
            });

            elevationControl.on('eledata_loaded', function() {
              setTimeout(updateStatsFromTrackInfo, 200);
            });

            map.on('click', function(e) {
              if (!elevationControl._data || !elevationControl._data.length) return;
              var data = elevationControl._data;
              var minDist = Infinity, nearest = null, nearestIdx = 0;
              for (var i = 0; i < data.length; i++) {
                var dx = e.latlng.lat - data[i].latlng.lat;
                var dy = e.latlng.lng - data[i].latlng.lng;
                var d = dx * dx + dy * dy;
                if (d < minDist) { minDist = d; nearest = data[i]; nearestIdx = i; }
              }
              if (nearest && nearest.z != null) {
                var dist = 0;
                for (var i = 1; i <= nearestIdx; i++) {
                  dist += haversine(
                    data[i - 1].latlng.lat, data[i - 1].latlng.lng,
                    data[i].latlng.lat, data[i].latlng.lng
                  );
                }
                var distKm = dist.toFixed(2);
                L.popup()
                  .setLatLng(e.latlng)
                  .setContent('<div class="route-popup"><strong>' + nearest.z.toFixed(0) + ' m</strong><br><small>' + distKm + ' km</small></div>')
                  .openOn(map);
              }
            });

            var toggleBtn = document.getElementById('elevation-toggle');
            var profileContainer = document.getElementById('elevation-profile');
            var arrow = document.getElementById('elevation-arrow');
            if (toggleBtn && profileContainer) {
              toggleBtn.addEventListener('click', function() {
                var isHidden = profileContainer.classList.contains('elevation-profile-hidden');
                profileContainer.classList.toggle('elevation-profile-hidden');
                profileContainer.classList.toggle('elevation-profile-visible');
                if (arrow) arrow.classList.toggle('elevation-arrow-rotated');
                map.invalidateSize();
                if (isHidden && elevationControl) {
                  setTimeout(function() { elevationControl.redraw(); }, 100);
                }
              });
            }

            var fsBtn = document.getElementById('fullscreen-btn');
            var fsExpand = document.getElementById('fs-icon-expand');
            var fsShrink = document.getElementById('fs-icon-shrink');
            var wrapper = document.getElementById('route-map-wrapper');

            function enterFullscreen() {
              wrapper.requestFullscreen().then(function() {
                wrapper.classList.add('map-fullscreen');
                if (profileContainer && profileContainer.classList.contains('elevation-profile-hidden')) {
                  profileContainer.classList.remove('elevation-profile-hidden');
                  profileContainer.classList.add('elevation-profile-visible');
                  if (arrow) arrow.classList.add('elevation-arrow-rotated');
                  if (elevationControl) setTimeout(function() { elevationControl.redraw(); }, 150);
                }
                map.invalidateSize();
                if (fsExpand) fsExpand.style.display = 'none';
                if (fsShrink) fsShrink.style.display = 'block';
              }).catch(function() {});
            }

            function exitFullscreen() {
              document.exitFullscreen().then(function() {
                wrapper.classList.remove('map-fullscreen');
                map.invalidateSize();
                if (elevationControl) setTimeout(function() { elevationControl.redraw(); }, 150);
                if (fsExpand) fsExpand.style.display = 'block';
                if (fsShrink) fsShrink.style.display = 'none';
              }).catch(function() {});
            }

            if (fsBtn && wrapper) {
              fsBtn.addEventListener('click', function() {
                if (!document.fullscreenElement) {
                  enterFullscreen();
                } else {
                  exitFullscreen();
                }
              });

              document.addEventListener('fullscreenchange', function() {
                if (!document.fullscreenElement) {
                  wrapper.classList.remove('map-fullscreen');
                  map.invalidateSize();
                  if (elevationControl) setTimeout(function() { elevationControl.redraw(); }, 150);
                  if (fsExpand) fsExpand.style.display = 'block';
                  if (fsShrink) fsShrink.style.display = 'none';
                }
              });
            }
          });
        </script>
      </div>
      
  </main>
</Layout>
