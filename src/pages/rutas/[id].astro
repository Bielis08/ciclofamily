---
import { getRutaById } from "../../lib/rutas";
import { getRutaImageUrl, getGpxFileUrl } from "../../lib/utils";
import { getMarkdownProcessor } from "../../lib/markdown";

import BtnRutas from "../../components/BtnRutas.astro";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/rutas");
}

const ruta = await getRutaById(id);

if (!ruta) {
  return Astro.redirect("/rutas");
}

const { titulo, destino, distancia, desnivel, gpx, wikiloc, dificultad, portada, descripcion } = ruta;

const gpxFileUrl = getGpxFileUrl(gpx);

let images: string[] = [];
try {
  const { supabase } = await import("../../lib/supabase");
  if (supabase) {
    const { data: storageFiles } = await supabase.storage.from("rutas-imagenes").list(id);
    images = (storageFiles ?? [])
      .filter((f) => f.name !== portada)
      .map((f) => getRutaImageUrl(id, f.name));
  }
} catch (error) {
  console.error("Error al obtener imágenes de la ruta:", error);
}

const portadaUrl = getRutaImageUrl(id, portada);

const processor = await getMarkdownProcessor();
const { code: descripcionHtml } = await processor.render(descripcion);

const dificultadClass =
  dificultad === "Fácil"
    ? "bg-facil"
    : dificultad === "Moderada"
      ? "bg-moderada"
      : dificultad === "Difícil"
        ? "bg-dificil"
        : "bg-gray-200 text-gray-800";

const pageTitle = `Ciclo Family | ${titulo}`;
const pageDescription = `Descubre la ruta en bicicleta ${titulo} en ${destino}. ${distancia} km de distancia, ${desnivel} m de desnivel. Dificultad ${dificultad}. Ideal para familias y ciclistas.`;
const canonicalUrl = `${Astro.url.origin}/rutas/${id}`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={portadaUrl}
  url={canonicalUrl}
  type="article"
  keywords={`rutas en bicicleta, ${destino}, ${titulo}, ciclismo Catalunya, rutas familiares, ${dificultad}`}
>
  <!-- Structured Data: TouristTrip -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    "name": titulo,
    "description": pageDescription,
    "url": canonicalUrl,
    "image": portadaUrl,
    "touristType": "Familia Ciclista",
    "itinerary": {
      "@type": "ItemList",
      "numberOfItems": 1,
      "itemListElement": {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Place",
          "name": destino,
          "description": `Ruta de ${distancia} km con ${desnivel} m de desnivel en ${destino}`
        }
      }
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    },
    "provider": {
      "@type": "Organization",
      "name": "Ciclo Family",
      "url": "https://ciclofamily.vercel.app"
    }
  })} />

  <!-- Structured Data: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://ciclofamily.vercel.app/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Rutas",
        "item": "https://ciclofamily.vercel.app/rutas"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": titulo,
        "item": canonicalUrl
      }
    ]
  })} />

  <Header />
  
  <main class="w-[90%] m-auto">
    <nav aria-label="Breadcrumb" class="text-sm text-gray-600 mx-8 pt-4">
      <ol class="flex items-center gap-1">
        <li><a href="/" class="hover:underline hover:text-page-400 transition">Inicio</a></li>
        <li aria-hidden="true" class="text-gray-400">›</li>
        <li><a href="/rutas" class="hover:underline hover:text-page-400 transition">Rutas</a></li>
        <li aria-hidden="true" class="text-gray-400">›</li>
        <li class="text-page-400 font-medium">{titulo}</li>
      </ol>
    </nav>

    <section class="flex items-center gap-4 m-4">
      <h1 class="text-2xl font-semibold">{titulo}</h1>
      <span class={`${dificultadClass} font-medium rounded-xl px-2 py-1`}>{dificultad}</span>
    </section>

    <div id="route-map" class="mx-auto z-0 rounded-xl w-full h-100"></div>

    <section class="bg-page-200/60 p-4 flex flex-wrap gap-4 rounded-xl my-2 sm:my-6 border-black border">
        <span class="flex items-center gap-1 mx-auto"><img class="size-7" src="/icons/ubicacion.svg" alt="Icono de ubicación"/><span class="flex flex-col sm:mx-2">Destino<b>{destino}</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/distancia.svg" alt="Icono de distancia"/><span class="flex flex-col sm:mx-2">Distancia<b>{distancia} km</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/desnivel.svg" alt="Icono de desnivel"/><span class="flex flex-col sm:mx-2">Desnivel<b>{desnivel} m</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/max.svg" alt="Icono de altitud máxima"/><span class="flex flex-col sm:mx-2">Altitud Máx<b id="alt-max">...</b></span></span>
        <span class="flex gap-1 items-center mx-auto"><img class="size-7" src="/icons/min.svg" alt="Icono de altitud mínima"/><span class="flex flex-col sm:mx-2">Altitud Mín<b id="alt-min">...</b></span></span>
      </section>

      <section class="flex flex-row gap-4 items-center text-sm sm:text-lg mt-4 sm:my-0">
        <a href={gpxFileUrl} class="bg-page-300/80 px-4 py-2 rounded-lg hover:bg-page-200 transition flex" target="_blank" rel="noopener noreferrer">Descargar GPX</a>
        <a href={wikiloc} class="bg-page-400 text-white hover:text-black rounded-lg py-2 px-4 hover:bg-page-200 transition flex items-center" target="_blank">Ver en <img class="ml-1 h-4 md:h-6" src="/Wikiloc.png" alt="Logo de Wikiloc" /></a>
      </section>

      <div id="mapa-leaflet-scripts">
        <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
        <script is:inline src="https://unpkg.com/@tmcw/togeojson@7.1.2/dist/togeojson.umd.js" crossorigin=""></script>
        <script define:vars={{ gpx, gpxFileUrl }} is:inline>
          document.addEventListener('DOMContentLoaded', function() {
            fetch('/api/gpx-altitudes?gpx=' + encodeURIComponent(gpx))
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.altMax != null) document.getElementById('alt-max').textContent = data.altMax + ' m';
                if (data.altMin != null) document.getElementById('alt-min').textContent = data.altMin + ' m';
              })
              .catch(function() {});

            var map = L.map('route-map').setView([41.5, 2.0], 8);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
              attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
            }).addTo(map);

            fetch(gpxFileUrl)
              .then(function(r) { return r.text(); })
              .then(function(gpxText) {
                var parser = new DOMParser();
                var gpxDoc = parser.parseFromString(gpxText, 'text/xml');
                var geojson = toGeoJSON.gpx(gpxDoc);

                var routeLayer = L.geoJSON(geojson, {
                  style: { color: '#3b82f6', weight: 4, opacity: 0.8 }
                }).addTo(map);

                map.fitBounds(routeLayer.getBounds(), { padding: [20, 20] });
              })
              .catch(function() {});
          });
        </script>
      </div>
      
  </main>
