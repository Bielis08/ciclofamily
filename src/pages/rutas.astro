---
import { supabase } from "../lib/supabase";
import { getCached, setCached } from "../lib/cache";
import ContainerRutas from "../components/ContainerRutas.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";

const CACHE_KEY = "rutas:all";
let rutas = [];

const cached = getCached<{ id: string; titulo: string }[]>(CACHE_KEY);
if (cached) {
  rutas = cached;
} else if (supabase) {
  try {
    const { data } = await supabase.from("rutas").select("*").order("titulo");
    const all = data ?? [];
    setCached(CACHE_KEY, all, 120_000);
    rutas = all;
  } catch (error) {
    console.error("Error al obtener rutas:", error);
  }
}
---

<Layout title="Ciclo Family | Todas las rutas en bicicleta por Catalunya">
    <Header />
    <main class="max-w-7xl mx-auto mt-40">
        <ContainerRutas rutas={rutas} />
    </main>
</Layout>