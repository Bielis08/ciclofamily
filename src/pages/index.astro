---
import Header from '../components/Header.astro';
import MiniHeader from '../components/MiniHeader.astro';
import PorqueCicloFamily from '../components/PorqueCicloFamily.astro';
import RutasDestacadas from '../components/RutasDestacadas.astro';
import Layout from '../layouts/Layout.astro';

const title = "Ciclo Family | Rutas en Bicicleta por Catalunya para Familias";
const description = "Descubre las mejores rutas en bicicleta por Catalunya para familias y grupos. Rutas de montaña seguras, información detallada y mapas interactivos. Ciclismo para todos los niveles.";
---

<Layout title={title} description={description} type="website">
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": "Ciclo Family",
		"url": "https://ciclofamily.vercel.app",
		"description": "Rutas en bicicleta por Catalunya para familias y grupos de ciclistas de montaña.",
		"potentialAction": {
			"@type": "SearchAction",
			"target": "https://ciclofamily.vercel.app/rutas?q={search_term_string}",
			"query-input": "required name=search_term_string"
		}
	})} />
	<Header />
	<MiniHeader />
	<main class="max-w-7xl mx-auto">
		<RutasDestacadas />
		<PorqueCicloFamily />
	</main>
</Layout>
